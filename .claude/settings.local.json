{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:docs.siderolabs.com)",
      "WebFetch(domain:budimanjojo.github.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:grafana.github.io)",
      "WebFetch(domain:prometheus-community.github.io)",
      "WebFetch(domain:fluxcd.io)",
      "Read(//tmp/**)",
      "Bash(talhelper --version)",
      "Bash(talhelper validate talconfig)",
      "Bash(SOPS_AGE_KEY_FILE=./age-key.txt talhelper genconfig --dry-run)",
      "Bash(SOPS_AGE_KEY_FILE=./age-key.txt talhelper genconfig)",
      "Bash(kubectl top nodes)",
      "Bash(kubectl run *)",
      "Bash(talosctl -n 192.168.1.236 stats)",
      "Bash(helm search hub lgtm --max-col-width 80)",
      "Bash(helm repo list)",
      "Bash(gh api *)",
      "Bash(dig +short +time=2 box.local @192.168.1.1)",
      "Bash(getent hosts *)",
      "Bash(xargs -I{} -P10 sh -c 'gh api \"repos/bbck/homelab/contents/{}?ref=master\" -H \"Accept: application/vnd.github.raw\" 2>/dev/null | grep -lE \"nfs:|server:.*192|/mnt/user|/export\" >/dev/null 2>&1 && echo \"{}\"')",
      "Bash(sed -i '' 's/namespace: manyfold$/namespace: default/' externalsecret.yaml postgres-pvc.yaml postgres.yaml redis.yaml manyfold.yaml ingress.yaml)",
      "Bash(sed -i '' 's/\\\\.manyfold\\\\.svc\\\\.cluster\\\\.local/.default.svc.cluster.local/g' manyfold.yaml)",
      "Bash(rm namespace.yaml)",
      "Bash(git pull *)",
      "Bash(git add *)",
      "Bash(python3 -m json.tool)"
    ]
  }
}
